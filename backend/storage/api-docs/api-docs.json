{
    "openapi": "3.0.0",
    "info": {
        "title": "LeaveHub API",
        "description": "Leave Request Management API Documentation",
        "contact": {
            "email": "admin@leavehub.com"
        },
        "version": "1.0.0"
    },
    "paths": {
        "/login": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "summary": "Login user",
                "description": "Authenticate user and return access token",
                "operationId": "login",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "admin@leavehub.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "password123"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login successful",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Login berhasil."
                                        },
                                        "data": {
                                            "properties": {
                                                "user": {
                                                    "properties": {
                                                        "id": {
                                                            "type": "integer"
                                                        },
                                                        "name": {
                                                            "type": "string"
                                                        },
                                                        "email": {
                                                            "type": "string"
                                                        },
                                                        "role": {
                                                            "type": "string"
                                                        }
                                                    },
                                                    "type": "object"
                                                },
                                                "token": {
                                                    "type": "string"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Invalid credentials"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "servers": [
                    {
                        "url": "/api",
                        "description": "API Server"
                    }
                ]
            }
        },
        "/logout": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "summary": "Logout user",
                "description": "Revoke current access token",
                "operationId": "logout",
                "responses": {
                    "200": {
                        "description": "Logout successful"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "servers": [
                    {
                        "url": "/api",
                        "description": "API Server"
                    }
                ]
            }
        },
        "/admin/users": {
            "get": {
                "tags": [
                    "Admin - User Management"
                ],
                "summary": "List all users",
                "operationId": "adminListUsers",
                "responses": {
                    "200": {
                        "description": "Success"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "403": {
                        "description": "Forbidden"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "servers": [
                    {
                        "url": "/api",
                        "description": "API Server"
                    }
                ]
            },
            "post": {
                "tags": [
                    "Admin - User Management"
                ],
                "summary": "Create new user",
                "description": "Create user (max 2). Leave balances auto-assigned.",
                "operationId": "adminCreateUser",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "John Doe"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "john@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "password123"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "User created"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "403": {
                        "description": "Forbidden"
                    },
                    "422": {
                        "description": "Validation error or max users reached"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "servers": [
                    {
                        "url": "/api",
                        "description": "API Server"
                    }
                ]
            }
        },
        "/admin/users/{id}": {
            "put": {
                "tags": [
                    "Admin - User Management"
                ],
                "summary": "Update user",
                "operationId": "adminUpdateUser",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "name": {
                                        "type": "string"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email"
                                    },
                                    "password": {
                                        "type": "string"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "User updated"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "403": {
                        "description": "Forbidden"
                    },
                    "404": {
                        "description": "Not found"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "servers": [
                    {
                        "url": "/api",
                        "description": "API Server"
                    }
                ]
            }
        },
        "/leave-balances": {
            "get": {
                "tags": [
                    "User - Leave Balance"
                ],
                "summary": "View own leave balances",
                "description": "Get current year leave balances",
                "operationId": "viewLeaveBalances",
                "responses": {
                    "200": {
                        "description": "Success",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string"
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "properties": {
                                                    "id": {
                                                        "type": "integer"
                                                    },
                                                    "leave_type": {
                                                        "properties": {
                                                            "id": {
                                                                "type": "integer"
                                                            },
                                                            "name": {
                                                                "type": "string"
                                                            }
                                                        },
                                                        "type": "object"
                                                    },
                                                    "year": {
                                                        "type": "integer"
                                                    },
                                                    "total_quota": {
                                                        "type": "integer"
                                                    },
                                                    "used": {
                                                        "type": "integer"
                                                    },
                                                    "remaining_quota": {
                                                        "type": "integer"
                                                    }
                                                },
                                                "type": "object"
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "servers": [
                    {
                        "url": "/api",
                        "description": "API Server"
                    }
                ]
            }
        },
        "/leave-requests": {
            "get": {
                "tags": [
                    "User - Leave Request"
                ],
                "summary": "View own leave requests",
                "operationId": "viewLeaveRequests",
                "responses": {
                    "200": {
                        "description": "Success"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "servers": [
                    {
                        "url": "/api",
                        "description": "API Server"
                    }
                ]
            },
            "post": {
                "tags": [
                    "User - Leave Request"
                ],
                "summary": "Submit leave request",
                "description": "Submit a new leave request. Validates quota and overlap.",
                "operationId": "submitLeaveRequest",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "leave_type_id",
                                    "start_date",
                                    "end_date",
                                    "reason"
                                ],
                                "properties": {
                                    "leave_type_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "start_date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2026-04-01"
                                    },
                                    "end_date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2026-04-03"
                                    },
                                    "reason": {
                                        "type": "string",
                                        "example": "Liburan keluarga"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Leave request created"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "servers": [
                    {
                        "url": "/api",
                        "description": "API Server"
                    }
                ]
            }
        },
        "/leave-requests/{id}/cancel": {
            "patch": {
                "tags": [
                    "User - Leave Request"
                ],
                "summary": "Cancel own leave request",
                "operationId": "cancelLeaveRequest",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Request cancelled"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "403": {
                        "description": "Not your request"
                    },
                    "404": {
                        "description": "Not found"
                    },
                    "422": {
                        "description": "Cannot cancel"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "servers": [
                    {
                        "url": "/api",
                        "description": "API Server"
                    }
                ]
            }
        },
        "/leave-requests/{id}": {
            "delete": {
                "tags": [
                    "User - Leave Request"
                ],
                "summary": "Soft delete own leave request",
                "description": "Soft delete own cancelled or rejected leave request",
                "operationId": "deleteLeaveRequest",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Request deleted"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "403": {
                        "description": "Not your request"
                    },
                    "422": {
                        "description": "Cannot delete"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "servers": [
                    {
                        "url": "/api",
                        "description": "API Server"
                    }
                ]
            }
        },
        "/admin/leave-requests": {
            "get": {
                "tags": [
                    "Admin - Leave Request"
                ],
                "summary": "View all leave requests",
                "operationId": "adminListLeaveRequests",
                "responses": {
                    "200": {
                        "description": "Success"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "403": {
                        "description": "Forbidden"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "servers": [
                    {
                        "url": "/api",
                        "description": "API Server"
                    }
                ]
            }
        },
        "/admin/leave-requests/{id}/approve": {
            "patch": {
                "tags": [
                    "Admin - Leave Request"
                ],
                "summary": "Approve leave request",
                "description": "Approve a pending leave request. Deducts user leave balance.",
                "operationId": "adminApproveLeaveRequest",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": false,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "admin_notes": {
                                        "type": "string",
                                        "example": "Disetujui."
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Request approved"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "403": {
                        "description": "Forbidden"
                    },
                    "422": {
                        "description": "Cannot approve"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "servers": [
                    {
                        "url": "/api",
                        "description": "API Server"
                    }
                ]
            }
        },
        "/admin/leave-requests/{id}/reject": {
            "patch": {
                "tags": [
                    "Admin - Leave Request"
                ],
                "summary": "Reject leave request",
                "operationId": "adminRejectLeaveRequest",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": false,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "admin_notes": {
                                        "type": "string",
                                        "example": "Ditolak."
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Request rejected"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "403": {
                        "description": "Forbidden"
                    },
                    "422": {
                        "description": "Cannot reject"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "servers": [
                    {
                        "url": "/api",
                        "description": "API Server"
                    }
                ]
            }
        },
        "/admin/leave-requests/{id}": {
            "delete": {
                "tags": [
                    "Admin - Leave Request"
                ],
                "summary": "Soft delete leave request",
                "description": "Soft delete a final-status leave request (admin only)",
                "operationId": "adminDeleteLeaveRequest",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Request deleted"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "403": {
                        "description": "Forbidden"
                    },
                    "422": {
                        "description": "Cannot delete"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "servers": [
                    {
                        "url": "/api",
                        "description": "API Server"
                    }
                ]
            }
        }
    },
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "description": "Enter your Sanctum token",
                "bearerFormat": "Token",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Authentication",
            "description": "Authentication"
        },
        {
            "name": "Admin - User Management",
            "description": "Admin - User Management"
        },
        {
            "name": "User - Leave Balance",
            "description": "User - Leave Balance"
        },
        {
            "name": "User - Leave Request",
            "description": "User - Leave Request"
        },
        {
            "name": "Admin - Leave Request",
            "description": "Admin - Leave Request"
        }
    ]
}